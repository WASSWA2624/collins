{
  "name": "collins-backend",
  "version": "0.1.0",
  "description": "Express + Prisma backend foundation for the AI Vent ventilation decision-support app.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/prisma-generate-if-needed.mjs",
    "predev": "node scripts/prisma-generate-if-needed.mjs",
    "dev": "nodemon --config nodemon.json",
    "prestart": "node scripts/prisma-generate-if-needed.mjs",
    "start": "node src/server.js",
    "prisma:generate": "node scripts/prisma-generate-if-needed.mjs",
    "prisma:generate:force": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "node prisma/seed.mjs",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .js",
    "pretest": "node scripts/prisma-generate-if-needed.mjs",
    "test": "node --test"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mariadb": "^3.5.2",
    "morgan": "^1.10.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.10",
    "prisma": "^7.8.0"
  },
  "private": true
}
