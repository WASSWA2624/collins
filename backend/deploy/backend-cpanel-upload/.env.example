# Collins Backend Environment
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
API_VERSION=v1

# MySQL connection string used by Prisma
DATABASE_URL="mysql://zelahco_collins:replace-with-database-password@localhost:3306/zelahco_collins"

# Security
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
CORS_ORIGIN="https://www.zelah.co.ug,https://zelah.co.ug"
BCRYPT_SALT_ROUNDS=12

# Logging
REQUEST_LOGGING=true
