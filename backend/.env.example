# Collins Backend Environment
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
API_VERSION=v1

# MySQL connection string used by Prisma
DATABASE_URL="mysql://root:password@localhost:3306/collins"

# Security
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
# Explicit browser origins. Development also allows localhost, Android emulator,
# and private LAN origins such as http://192.168.1.25:8081.
# Production example: https://www.zelah.co.ug,https://zelah.co.ug
CORS_ORIGIN="http://localhost:8081,http://localhost:19006,http://localhost:3000"
BCRYPT_SALT_ROUNDS=12

# Logging
REQUEST_LOGGING=true
