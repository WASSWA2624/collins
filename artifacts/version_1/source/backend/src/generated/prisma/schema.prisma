generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DEACTIVATED
}

enum FacilityVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum MembershipRole {
  PLATFORM_ADMIN
  FACILITY_ADMIN
  CLINICIAN
  ICU_NURSE
  SPECIALIST_REVIEWER
  RESEARCH_GOVERNANCE_OFFICER
  MODEL_GOVERNANCE_OFFICER
  READ_ONLY_REVIEWER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum PatientPathway {
  NEONATE
  INFANT
  CHILD
  ADOLESCENT
  ADULT
  OBSTETRIC
  BURNS
  TRAUMA
  PERI_OPERATIVE
  MEDICAL
  SURGICAL
  UNKNOWN
  OTHER
}

enum SexForSizeCalculations {
  MALE
  FEMALE
  UNKNOWN
}

enum AdmissionStatus {
  ACTIVE
  TRANSFERRED
  DISCHARGED
  DECEASED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  CORRECTION_REQUESTED
  EXCLUDED
}

enum OutcomeType {
  EXTUBATED
  TRANSFERRED
  DISCHARGED
  DECEASED
  STILL_ADMITTED
  OTHER
}

enum DatasetReviewStatus {
  DRAFT
  SUBMITTED
  NEEDS_CORRECTION
  REVIEWED
  APPROVED_FOR_DATASET
  APPROVED_FOR_TRAINING
  EXCLUDED
}

enum ReferenceRuleVerificationStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  CORRECTION_REQUESTED
  REJECTED
  RETIRED
}

enum ReferenceScope {
  GLOBAL
  FACILITY
}

enum ModelApprovalStatus {
  DRAFT
  SHADOW_MODE
  APPROVED_FOR_LIVE_SUPPORT
  RETIRED
}

enum SyncStatus {
  LOCAL_DRAFT
  WAITING_TO_SYNC
  SYNCING
  SYNCED
  DUPLICATE
  CONFLICT
  FAILED
  FAILED_VALIDATION
  NEEDS_REVIEW
  REVIEWED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OnboardingStep {
  WELCOME
  CLINICAL_SAFETY
  USER_SETUP
  FACILITY_SELECTION
  MEMBERSHIP_REQUEST
  COMPLETED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String     @map("password_hash")
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  onboardingState             OnboardingState?
  facilityMemberships         FacilityMembership[]     @relation("FacilityMembershipUser")
  approvedFacilityMemberships FacilityMembership[]     @relation("FacilityMembershipApprover")
  admissionsCreated           Admission[]              @relation("AdmissionCreator")
  snapshotsEntered            ClinicalSnapshot[]       @relation("ClinicalSnapshotEnteredBy")
  abgTestsEntered             AbgTest[]                @relation("AbgTestEnteredBy")
  abgTestsReviewed            AbgTest[]                @relation("AbgTestReviewedBy")
  ventilatorSettingsEntered   VentilatorSetting[]      @relation("VentilatorSettingEnteredBy")
  airwayDevicesEntered        AirwayDevice[]           @relation("AirwayDeviceEnteredBy")
  humidificationsConfirmed    HumidificationDecision[] @relation("HumidificationConfirmedBy")
  dailyReviews                DailyVentilationReview[] @relation("DailyReviewReviewer")
  outcomesEntered             Outcome[]                @relation("OutcomeEnteredBy")
  datasetCasesApproved        DatasetCase[]            @relation("DatasetApprovedBy")
  datasetCasesReviewed        DatasetCase[]            @relation("DatasetReviewedBy")
  referenceRulesApproved      ReferenceRule[]          @relation("ReferenceRuleApprovedBy")
  referenceRulesVerified      ReferenceRule[]          @relation("ReferenceRuleVerifiedBy")
  reviewActions               ReviewAction[]           @relation("ReviewActionReviewer")
  refreshSessions             RefreshSession[]
  idempotencyRecords          IdempotencyRecord[]      @relation("IdempotencyUser")
  syncEvents                  SyncEvent[]              @relation("SyncEventUser")
  auditLogs                   AuditLog[]               @relation("AuditLogUser")
  settings                    UserSettings?

  @@map("user")
}

model RefreshSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_session")
}

model OnboardingState {
  id                                   String           @id @default(cuid())
  userId                               String           @unique @map("user_id")
  status                               OnboardingStatus @default(NOT_STARTED)
  currentStep                          OnboardingStep   @default(WELCOME) @map("current_step")
  completedStepsJson                   Json?            @map("completed_steps_json")
  selectedFacilityId                   String?          @map("selected_facility_id")
  requestedRole                        MembershipRole?  @map("requested_role")
  clinicalSafetyAcknowledgedAt         DateTime?        @map("clinical_safety_acknowledged_at")
  clinicalSafetyAcknowledgementVersion String?          @map("clinical_safety_acknowledgement_version")
  clinicalSafetyStatementHash          String?          @map("clinical_safety_statement_hash")
  completedAt                          DateTime?        @map("completed_at")
  createdAt                            DateTime         @default(now()) @map("created_at")
  updatedAt                            DateTime         @updatedAt @map("updated_at")

  user             User      @relation(fields: [userId], references: [id])
  selectedFacility Facility? @relation(fields: [selectedFacilityId], references: [id])

  @@index([selectedFacilityId, status])
  @@index([status, currentStep])
  @@map("onboarding_state")
}

model Facility {
  id                    String                     @id @default(cuid())
  registryCode          String?                    @unique @map("registry_code")
  name                  String
  district              String?
  region                String?
  type                  String?
  ownership             String?
  verificationStatus    FacilityVerificationStatus @default(PENDING) @map("verification_status")
  oxygenProfileJson     Json?                      @map("oxygen_profile_json")
  ventilatorProfileJson Json?                      @map("ventilator_profile_json")
  abgAvailability       String?                    @map("abg_availability")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  memberships          FacilityMembership[]
  onboardingSelections OnboardingState[]
  patients             Patient[]
  admissions           Admission[]
  datasetCases         DatasetCase[]
  referenceRules       ReferenceRule[]
  reviewActions        ReviewAction[]
  idempotencyRecords   IdempotencyRecord[]
  syncEvents           SyncEvent[]
  auditLogs            AuditLog[]
  settings             FacilitySettings?
  identifierSequence   FacilityIdentifierSequence?
  activeUserSettings   UserSettings[]              @relation("ActiveFacilityUserSettings")

  @@map("facility")
}

model FacilityIdentifierSequence {
  id                String   @id @default(cuid())
  facilityId        String   @unique @map("facility_id")
  patientSequence   Int      @default(0) @map("patient_sequence")
  admissionSequence Int      @default(0) @map("admission_sequence")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  facility Facility @relation(fields: [facilityId], references: [id])

  @@map("facility_identifier_sequence")
}

model UserSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique @map("user_id")
  activeFacilityId           String?  @map("active_facility_id")
  roleVisibilityJson         Json?    @map("role_visibility_json")
  displayPreferencesJson     Json?    @map("display_preferences_json")
  offlineSyncPreferencesJson Json?    @map("offline_sync_preferences_json")
  privacyControlsJson        Json?    @map("privacy_controls_json")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id])
  activeFacility Facility? @relation("ActiveFacilityUserSettings", fields: [activeFacilityId], references: [id])

  @@index([activeFacilityId])
  @@map("user_settings")
}

model FacilitySettings {
  id                     String   @id @default(cuid())
  facilityId             String   @unique @map("facility_id")
  referenceSettingsJson  Json?    @map("reference_settings_json")
  workflowSettingsJson   Json?    @map("workflow_settings_json")
  privacyControlsJson    Json?    @map("privacy_controls_json")
  governanceSettingsJson Json?    @map("governance_settings_json")
  modelVisibilityJson    Json?    @map("model_visibility_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  facility Facility @relation(fields: [facilityId], references: [id])

  @@map("facility_settings")
}

model FacilityMembership {
  id               String           @id @default(cuid())
  userId           String           @map("user_id")
  facilityId       String           @map("facility_id")
  role             MembershipRole
  status           MembershipStatus @default(PENDING)
  approvedByUserId String?          @map("approved_by_user_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user       User     @relation("FacilityMembershipUser", fields: [userId], references: [id])
  facility   Facility @relation(fields: [facilityId], references: [id])
  approvedBy User?    @relation("FacilityMembershipApprover", fields: [approvedByUserId], references: [id])

  @@unique([userId, facilityId, role])
  @@index([facilityId, status])
  @@index([userId, status])
  @@map("facility_membership")
}

model Patient {
  id                     String                 @id @default(cuid())
  facilityId             String                 @map("facility_id")
  appPatientCode         String                 @map("app_patient_code") @db.VarChar(32)
  optionalName           String?                @map("optional_name")
  firstName              String?                @map("first_name")
  lastName               String?                @map("last_name")
  hospitalNumber         String?                @map("hospital_number")
  patientPathway         PatientPathway         @map("patient_pathway")
  dateOfBirth            DateTime?              @map("date_of_birth")
  ageYears               Int?                   @map("age_years")
  ageMonths              Int?                   @map("age_months")
  ageDays                Int?                   @map("age_days")
  estimatedAge           Boolean                @default(false) @map("estimated_age")
  gestationalAgeWeeks    Float?                 @map("gestational_age_weeks")
  correctedAgeWeeks      Float?                 @map("corrected_age_weeks")
  sexForSizeCalculations SexForSizeCalculations @default(UNKNOWN) @map("sex_for_size_calculations")
  actualWeightKg         Float?                 @map("actual_weight_kg")
  heightOrLengthCm       Float?                 @map("height_or_length_cm")
  referenceWeightKg      Float?                 @map("reference_weight_kg")
  referenceWeightMethod  String?                @map("reference_weight_method")
  pathwayDetailsJson     Json?                  @map("pathway_details_json")
  createdAt              DateTime               @default(now()) @map("created_at")
  updatedAt              DateTime               @updatedAt @map("updated_at")

  facility   Facility    @relation(fields: [facilityId], references: [id])
  admissions Admission[]

  @@unique([facilityId, appPatientCode])
  @@index([facilityId, hospitalNumber])
  @@index([facilityId, patientPathway])
  @@map("patient")
}

model Admission {
  id                   String          @id @default(cuid())
  patientId            String          @map("patient_id")
  facilityId           String          @map("facility_id")
  appAdmissionCode     String          @map("app_admission_code") @db.VarChar(32)
  bedNumber            String?         @map("bed_number")
  admittedAt           DateTime        @default(now()) @map("admitted_at")
  admissionSource      String?         @map("admission_source")
  reasonForVentilation String?         @map("reason_for_ventilation")
  status               AdmissionStatus @default(ACTIVE)
  createdByUserId      String?         @map("created_by_user_id")
  reviewStatus         ReviewStatus    @default(PENDING) @map("review_status")
  clientRecordId       String?         @map("client_record_id")
  deviceId             String?         @map("device_id")
  clientCreatedAt      DateTime?       @map("client_created_at")
  clientUpdatedAt      DateTime?       @map("client_updated_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  patient   Patient  @relation(fields: [patientId], references: [id])
  facility  Facility @relation(fields: [facilityId], references: [id])
  createdBy User?    @relation("AdmissionCreator", fields: [createdByUserId], references: [id])

  clinicalSnapshots       ClinicalSnapshot[]
  abgTests                AbgTest[]
  ventilatorSettings      VentilatorSetting[]
  airwayDevices           AirwayDevice[]
  humidificationDecisions HumidificationDecision[]
  dailyReviews            DailyVentilationReview[]
  outcomes                Outcome[]
  datasetCases            DatasetCase[]
  modelOutputs            ModelOutput[]

  @@unique([facilityId, appAdmissionCode])
  @@index([facilityId, status])
  @@index([patientId])
  @@index([clientRecordId])
  @@map("admission")
}

model ClinicalSnapshot {
  id                   String    @id @default(cuid())
  admissionId          String    @map("admission_id")
  measuredAt           DateTime  @default(now()) @map("measured_at")
  oxygenSupportType    String?   @map("oxygen_support_type")
  heartRate            Float?    @map("heart_rate")
  respiratoryRate      Float?    @map("respiratory_rate")
  systolicBp           Float?    @map("systolic_bp")
  diastolicBp          Float?    @map("diastolic_bp")
  meanArterialPressure Float?    @map("mean_arterial_pressure")
  temperatureC         Float?    @map("temperature_c")
  spo2                 Float?
  fio2                 Float?
  gcs                  Float?
  avpu                 String?
  rass                 Float?
  mainCondition        String?   @map("main_condition")
  comorbiditiesJson    Json?     @map("comorbidities_json")
  validationStatus     String?   @map("validation_status")
  source               String?
  enteredByUserId      String?   @map("entered_by_user_id")
  clientRecordId       String?   @map("client_record_id")
  deviceId             String?   @map("device_id")
  clientCreatedAt      DateTime? @map("client_created_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id])
  enteredBy User?     @relation("ClinicalSnapshotEnteredBy", fields: [enteredByUserId], references: [id])

  @@index([admissionId, measuredAt])
  @@index([clientRecordId])
  @@map("clinical_snapshot")
}

model AbgTest {
  id                     String       @id @default(cuid())
  admissionId            String       @map("admission_id")
  version                Int          @default(1)
  collectedAt            DateTime     @default(now()) @map("collected_at")
  ph                     Float?
  pao2                   Float?
  paco2                  Float?
  hco3                   Float?
  baseExcess             Float?       @map("base_excess")
  lactate                Float?
  fio2AtSample           Float?       @map("fio2_at_sample")
  spo2AtSample           Float?       @map("spo2_at_sample")
  source                 String?
  validationStatus       String?      @map("validation_status")
  clinicalFlagsJson      Json?        @map("clinical_flags_json")
  calculationSummaryJson Json?        @map("calculation_summary_json")
  enteredByUserId        String?      @map("entered_by_user_id")
  reviewedByUserId       String?      @map("reviewed_by_user_id")
  reviewStatus           ReviewStatus @default(PENDING) @map("review_status")
  clientRecordId         String?      @map("client_record_id")
  deviceId               String?      @map("device_id")
  clientCreatedAt        DateTime?    @map("client_created_at")
  clientUpdatedAt        DateTime?    @map("client_updated_at")
  createdAt              DateTime     @default(now()) @map("created_at")

  admission  Admission @relation(fields: [admissionId], references: [id])
  enteredBy  User?     @relation("AbgTestEnteredBy", fields: [enteredByUserId], references: [id])
  reviewedBy User?     @relation("AbgTestReviewedBy", fields: [reviewedByUserId], references: [id])

  @@unique([admissionId, version])
  @@index([admissionId, collectedAt])
  @@index([reviewStatus])
  @@index([clientRecordId])
  @@map("abg_test")
}

model VentilatorSetting {
  id                       String       @id @default(cuid())
  admissionId              String       @map("admission_id")
  version                  Int          @default(1)
  measuredAt               DateTime     @default(now()) @map("measured_at")
  mode                     String?
  tidalVolumeMl            Float?       @map("tidal_volume_ml")
  respiratoryRateSet       Float?       @map("respiratory_rate_set")
  respiratoryRateMeasured  Float?       @map("respiratory_rate_measured")
  fio2                     Float?
  peep                     Float?
  pressureSupport          Float?       @map("pressure_support")
  inspiratoryPressure      Float?       @map("inspiratory_pressure")
  peakPressure             Float?       @map("peak_pressure")
  plateauPressure          Float?       @map("plateau_pressure")
  ieRatio                  String?      @map("ie_ratio")
  minuteVolumeLMin         Float?       @map("minute_volume_l_min")
  vtMlPerKgReferenceWeight Float?       @map("vt_ml_per_kg_reference_weight")
  drivingPressure          Float?       @map("driving_pressure")
  source                   String?
  validationStatus         String?      @map("validation_status")
  clinicalFlagsJson        Json?        @map("clinical_flags_json")
  calculationSummaryJson   Json?        @map("calculation_summary_json")
  enteredByUserId          String?      @map("entered_by_user_id")
  reviewStatus             ReviewStatus @default(PENDING) @map("review_status")
  clientRecordId           String?      @map("client_record_id")
  deviceId                 String?      @map("device_id")
  clientCreatedAt          DateTime?    @map("client_created_at")
  clientUpdatedAt          DateTime?    @map("client_updated_at")
  createdAt                DateTime     @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id])
  enteredBy User?     @relation("VentilatorSettingEnteredBy", fields: [enteredByUserId], references: [id])

  @@unique([admissionId, version])
  @@index([admissionId, measuredAt])
  @@index([reviewStatus])
  @@index([clientRecordId])
  @@map("ventilator_setting")
}

model AirwayDevice {
  id                 String    @id @default(cuid())
  admissionId        String    @map("admission_id")
  measuredAt         DateTime  @default(now()) @map("measured_at")
  airwayRoute        String?   @map("airway_route")
  tubeType           String?   @map("tube_type")
  internalDiameterMm Float?    @map("internal_diameter_mm")
  depthCm            Float?    @map("depth_cm")
  cuffPressureCmH2O  Float?    @map("cuff_pressure_cm_h2o")
  tubeSecured        Boolean?  @map("tube_secured")
  notes              String?   @db.Text
  validationStatus   String?   @map("validation_status")
  clinicalFlagsJson  Json?     @map("clinical_flags_json")
  enteredByUserId    String?   @map("entered_by_user_id")
  clientRecordId     String?   @map("client_record_id")
  deviceId           String?   @map("device_id")
  clientCreatedAt    DateTime? @map("client_created_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id])
  enteredBy User?     @relation("AirwayDeviceEnteredBy", fields: [enteredByUserId], references: [id])

  @@index([admissionId, measuredAt])
  @@index([clientRecordId])
  @@map("airway_device")
}

model HumidificationDecision {
  id                      String    @id @default(cuid())
  admissionId             String    @map("admission_id")
  measuredAt              DateTime  @default(now()) @map("measured_at")
  method                  String?
  thickSecretions         Boolean?  @map("thick_secretions")
  highMinuteVentilation   Boolean?  @map("high_minute_ventilation")
  hypothermia             Boolean?
  airwayBleeding          Boolean?  @map("airway_bleeding")
  expectedLongVentilation Boolean?  @map("expected_long_ventilation")
  suggestedOption         String?   @map("suggested_option")
  confirmedOption         String?   @map("confirmed_option")
  clinicalFlagsJson       Json?     @map("clinical_flags_json")
  confirmedByUserId       String?   @map("confirmed_by_user_id")
  clientRecordId          String?   @map("client_record_id")
  deviceId                String?   @map("device_id")
  clientCreatedAt         DateTime? @map("client_created_at")
  createdAt               DateTime  @default(now()) @map("created_at")

  admission   Admission @relation(fields: [admissionId], references: [id])
  confirmedBy User?     @relation("HumidificationConfirmedBy", fields: [confirmedByUserId], references: [id])

  @@index([admissionId, measuredAt])
  @@index([clientRecordId])
  @@map("humidification_decision")
}

model DailyVentilationReview {
  id                   String    @id @default(cuid())
  admissionId          String    @map("admission_id")
  reviewDate           DateTime  @default(now()) @map("review_date")
  oxygenationStable    Boolean?  @map("oxygenation_stable")
  hemodynamicsStable   Boolean?  @map("hemodynamics_stable")
  sedationLightEnough  Boolean?  @map("sedation_light_enough")
  secretionsManageable Boolean?  @map("secretions_manageable")
  sbtStatus            String?   @map("sbt_status")
  sbtFailureReason     String?   @map("sbt_failure_reason")
  proneStatus          String?   @map("prone_status")
  vapBundleJson        Json?     @map("vap_bundle_json")
  clinicalFlagsJson    Json?     @map("clinical_flags_json")
  reviewedByUserId     String?   @map("reviewed_by_user_id")
  clientRecordId       String?   @map("client_record_id")
  deviceId             String?   @map("device_id")
  clientCreatedAt      DateTime? @map("client_created_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  admission  Admission @relation(fields: [admissionId], references: [id])
  reviewedBy User?     @relation("DailyReviewReviewer", fields: [reviewedByUserId], references: [id])

  @@index([admissionId, reviewDate])
  @@index([clientRecordId])
  @@map("daily_ventilation_review")
}

model Outcome {
  id                       String      @id @default(cuid())
  admissionId              String      @map("admission_id")
  outcomeType              OutcomeType @map("outcome_type")
  outcomeDate              DateTime?   @map("outcome_date")
  ventilatorDays           Float?      @map("ventilator_days")
  icuLengthOfStayDays      Float?      @map("icu_length_of_stay_days")
  hospitalLengthOfStayDays Float?      @map("hospital_length_of_stay_days")
  reintubationWithin48h    Boolean?    @map("reintubation_within_48h")
  tracheostomy             Boolean?
  vapSuspected             Boolean?    @map("vap_suspected")
  notes                    String?     @db.Text
  enteredByUserId          String?     @map("entered_by_user_id")
  clientRecordId           String?     @map("client_record_id")
  deviceId                 String?     @map("device_id")
  clientCreatedAt          DateTime?   @map("client_created_at")
  createdAt                DateTime    @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id])
  enteredBy User?     @relation("OutcomeEnteredBy", fields: [enteredByUserId], references: [id])

  @@index([admissionId, outcomeDate])
  @@index([clientRecordId])
  @@map("outcome")
}

model ReviewAction {
  id                  String   @id @default(cuid())
  facilityId          String?  @map("facility_id")
  reviewerUserId      String?  @map("reviewer_user_id")
  entityType          String   @map("entity_type")
  entityId            String   @map("entity_id")
  action              String
  statusBefore        String?  @map("status_before")
  statusAfter         String?  @map("status_after")
  validationStatus    String?  @map("validation_status")
  triagePriority      String?  @map("triage_priority")
  overrideReason      String?  @map("override_reason") @db.Text
  correctionJson      Json?    @map("correction_json")
  returnedToClinician Boolean  @default(false) @map("returned_to_clinician")
  comment             String?  @db.Text
  beforeJson          Json?    @map("before_json")
  afterJson           Json?    @map("after_json")
  createdAt           DateTime @default(now()) @map("created_at")

  facility Facility? @relation(fields: [facilityId], references: [id])
  reviewer User?     @relation("ReviewActionReviewer", fields: [reviewerUserId], references: [id])

  @@index([facilityId, entityType, entityId])
  @@index([reviewerUserId, createdAt])
  @@map("review_action")
}

model DatasetCase {
  id                      String              @id @default(cuid())
  facilityId              String              @map("facility_id")
  sourceAdmissionId       String?             @map("source_admission_id")
  sourceType              String              @map("source_type")
  sourcePayloadJson       Json?               @map("source_payload_json")
  structuredPreviewJson   Json?               @map("structured_preview_json")
  deidentifiedPayloadJson Json                @map("deidentified_payload_json")
  deidentificationStatus  String?             @map("deidentification_status")
  reviewStatus            DatasetReviewStatus @default(SUBMITTED) @map("review_status")
  approvedForTraining     Boolean             @default(false) @map("approved_for_training")
  approvedByUserId        String?             @map("approved_by_user_id")
  reviewedByUserId        String?             @map("reviewed_by_user_id")
  reviewedAt              DateTime?           @map("reviewed_at")
  ethicsApprovalId        String?             @map("ethics_approval_id")
  governanceJson          Json?               @map("governance_json")
  datasetVersion          String?             @map("dataset_version")
  exclusionReason         String?             @map("exclusion_reason") @db.Text
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")

  facility        Facility   @relation(fields: [facilityId], references: [id])
  sourceAdmission Admission? @relation(fields: [sourceAdmissionId], references: [id])
  approvedBy      User?      @relation("DatasetApprovedBy", fields: [approvedByUserId], references: [id])
  reviewedBy      User?      @relation("DatasetReviewedBy", fields: [reviewedByUserId], references: [id])

  @@index([facilityId, reviewStatus])
  @@index([approvedForTraining, datasetVersion])
  @@index([sourceAdmissionId])
  @@map("dataset_case")
}

model ReferenceRule {
  id                 String                          @id @default(cuid())
  facilityId         String?                         @map("facility_id")
  name               String
  version            String
  clinicalCondition  String?                         @map("clinical_condition")
  scenario           String?
  patientPathway     PatientPathway?                 @map("patient_pathway")
  population         String?
  scope              ReferenceScope                  @default(GLOBAL)
  parameterName      String?                         @map("parameter_name")
  lowerBound         Float?                          @map("lower_bound")
  upperBound         Float?                          @map("upper_bound")
  unit               String?
  sourceCitation     String?                         @map("source_citation") @db.Text
  ruleJson           Json                            @map("rule_json")
  activeFrom         DateTime?                       @map("active_from")
  activeTo           DateTime?                       @map("active_to")
  approvedByUserId   String?                         @map("approved_by_user_id")
  verifiedByUserId   String?                         @map("verified_by_user_id")
  verifiedAt         DateTime?                       @map("verified_at")
  verificationStatus ReferenceRuleVerificationStatus @default(PENDING_REVIEW) @map("verification_status")
  reviewNotes        String?                         @map("review_notes") @db.Text
  auditTrailJson     Json?                           @map("audit_trail_json")
  governanceStatus   String?                         @map("governance_status")
  createdAt          DateTime                        @default(now()) @map("created_at")
  updatedAt          DateTime                        @updatedAt @map("updated_at")

  facility   Facility? @relation(fields: [facilityId], references: [id])
  approvedBy User?     @relation("ReferenceRuleApprovedBy", fields: [approvedByUserId], references: [id])
  verifiedBy User?     @relation("ReferenceRuleVerifiedBy", fields: [verifiedByUserId], references: [id])

  @@unique([name, version])
  @@index([activeFrom, activeTo])
  @@index([parameterName, patientPathway, population])
  @@index([facilityId, verificationStatus])
  @@index([verificationStatus, activeFrom, activeTo])
  @@map("reference_rule")
}

model ModelVersion {
  id                     String              @id @default(cuid())
  modelName              String              @map("model_name")
  version                String
  trainingDatasetVersion String?             @map("training_dataset_version")
  intendedUse            String?             @map("intended_use") @db.Text
  contraindicatedUse     String?             @map("contraindicated_use") @db.Text
  performanceSummaryJson Json?               @map("performance_summary_json")
  calibrationSummaryJson Json?               @map("calibration_summary_json")
  biasAssessmentJson     Json?               @map("bias_assessment_json")
  approvalStatus         ModelApprovalStatus @default(DRAFT) @map("approval_status")
  activatedAt            DateTime?           @map("activated_at")
  retiredAt              DateTime?           @map("retired_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")

  outputs ModelOutput[]

  @@unique([modelName, version])
  @@index([approvalStatus])
  @@map("model_version")
}

model ModelOutput {
  id                  String   @id @default(cuid())
  modelVersionId      String   @map("model_version_id")
  facilityId          String?  @map("facility_id")
  sourceAdmissionId   String?  @map("source_admission_id")
  inputSummaryJson    Json     @map("input_summary_json")
  outputJson          Json     @map("output_json")
  visibleToClinicians Boolean  @default(false) @map("visible_to_clinicians")
  createdAt           DateTime @default(now()) @map("created_at")

  modelVersion    ModelVersion @relation(fields: [modelVersionId], references: [id])
  sourceAdmission Admission?   @relation(fields: [sourceAdmissionId], references: [id])

  @@index([modelVersionId, createdAt])
  @@index([facilityId, createdAt])
  @@index([sourceAdmissionId])
  @@map("model_output")
}

model IdempotencyRecord {
  id             String     @id @default(cuid())
  userId         String?    @map("user_id")
  facilityId     String?    @map("facility_id")
  key            String
  operation      String
  requestHash    String     @map("request_hash")
  responseJson   Json?      @map("response_json")
  status         SyncStatus @default(SYNCED)
  entityType     String?    @map("entity_type")
  entityId       String?    @map("entity_id")
  clientRecordId String?    @map("client_record_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user     User?     @relation("IdempotencyUser", fields: [userId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@unique([userId, key])
  @@index([facilityId, operation])
  @@index([clientRecordId])
  @@map("idempotency_record")
}

model SyncEvent {
  id                  String     @id @default(cuid())
  userId              String?    @map("user_id")
  facilityId          String?    @map("facility_id")
  operation           String
  entityType          String?    @map("entity_type")
  entityId            String?    @map("entity_id")
  clientRecordId      String?    @map("client_record_id")
  idempotencyKey      String?    @map("idempotency_key")
  status              SyncStatus @default(WAITING_TO_SYNC)
  requestPayloadJson  Json?      @map("request_payload_json")
  responsePayloadJson Json?      @map("response_payload_json")
  conflictPayloadJson Json?      @map("conflict_payload_json")
  errorMessage        String?    @map("error_message") @db.Text
  clientCreatedAt     DateTime?  @map("client_created_at")
  clientUpdatedAt     DateTime?  @map("client_updated_at")
  deviceId            String?    @map("device_id")
  receivedAt          DateTime   @default(now()) @map("received_at")
  resolvedAt          DateTime?  @map("resolved_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  user     User?     @relation("SyncEventUser", fields: [userId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([facilityId, status])
  @@index([clientRecordId])
  @@index([idempotencyKey])
  @@map("sync_event")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  facilityId String?  @map("facility_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  reason     String?  @db.Text
  requestId  String?  @map("request_id")
  ipHash     String?  @map("ip_hash")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User?     @relation("AuditLogUser", fields: [userId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([facilityId, entityType, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_log")
}
