{
  "watch": [
    "src",
    "prisma/schema.prisma",
    ".env.development",
    ".env.production"
  ],
  "ext": "js,mjs,cjs,json,prisma",
  "ignore": [
    "node_modules/**",
    "prisma/migrations/**",
    "tests/**",
    "app-rules/**",
    "dev-plan/**",
    "*.md"
  ],
  "exec": "node src/server.js"
}
